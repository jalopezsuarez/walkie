<?xml version="1.0" encoding="utf-8"?>
<!-- HTTPS only: never allow cleartext (HTTP) traffic; trust the system CAs. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
